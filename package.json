{
  "name": "vibe-printing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Planning and pipeline contracts for automated AI-generated YouTube Shorts.",
  "workspaces": [
    ".",
    "web"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "plan": "tsx src/index.ts",
    "n8n": "tsx src/n8n-cli.ts",
    "export:workflows": "tsx src/n8n-export.ts",
    "check": "npm run build",
    "generate": "tsx src/generate.ts",
    "web:dev": "npm --workspace @vibe-printing/web run dev",
    "web:build": "npm --workspace @vibe-printing/web run build",
    "web:start": "npm --workspace @vibe-printing/web run start"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@anthropic-ai/sdk": "^0.82.0",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@google/generative-ai": "^0.24.1",
    "@remotion/bundler": "^4.0.445",
    "@remotion/captions": "^4.0.445",
    "@remotion/google-fonts": "^4.0.452",
    "@remotion/media-utils": "^4.0.445",
    "@remotion/renderer": "^4.0.445",
    "dotenv": "^17.4.0",
    "edge-tts": "^1.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^171.4.0",
    "pexels": "^1.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remotion": "^4.0.445"
  }
}
