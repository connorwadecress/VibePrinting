# Brand-specific credentials
# Copy this file to .env inside your brand folder and fill in the values.
# These override any matching keys in the root .env.

# YouTube — OAuth2 credentials for your YouTube channel
# Run .\Get-YouTubeToken.ps1 -ClientId <id> -ClientSecret <secret> to generate your refresh token.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=

# TikTok — Content Posting API credentials
# Run .\Get-TikTokToken.ps1 -ClientKey <key> -ClientSecret <secret> to get tokens.
# Access tokens expire in ~24 hours. The pipeline auto-refreshes via TIKTOK_REFRESH_TOKEN.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# Optional: Override TTS voice/rate per brand (defaults come from channel.json)
# TTS_VOICE=en-US-GuyNeural
# TTS_RATE=+10%
