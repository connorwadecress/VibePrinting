# -------------------------------------------------------------------------
# Root .env — only user definitions live here.
# All other configuration (API keys, LLM, TTS, YouTube, TikTok) is set
# per-brand through the admin UI and stored in brands/<id>/.env.
# -------------------------------------------------------------------------

# Per-user accounts. Each user can only see and manage their own brands.
# Add up to 20 users by incrementing the suffix.
# BRANDS is a comma-separated list of brand folder names.

VP_USER_1_ID=
VP_USER_1_TOKEN=
VP_USER_1_BRANDS=

# VP_USER_2_ID=
# VP_USER_2_TOKEN=
# VP_USER_2_BRANDS=

# Maximum simultaneous pipeline runs across all users (default: 1).
VP_MAX_CONCURRENT_JOBS=1
