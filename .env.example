# LLM Provider: "claude" or "gemini"
LLM_PROVIDER=claude

# Claude / Anthropic (default provider)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# Gemini (alternative free provider)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Pexels (free stock footage - get key at https://www.pexels.com/api/)
PEXELS_API_KEY=

# TTS voice settings
TTS_VOICE=en-US-GuyNeural
TTS_RATE=+10%

# YouTube — SignalDrop (@signaldropyt)
# Run .\Get-YouTubeToken.ps1 -ClientId <id> -ClientSecret <secret> to generate your refresh token.
# Then paste the values below. After that, use: .\generate.ps1 -Upload
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxx  # Found in YouTube Studio -> Customisation -> Basic info

# TikTok — SignalDrop
# Setup steps:
#   1. In TikTok Developer Portal, open your app -> Products -> add "Content Posting API"
#   2. Under Content Posting API, enable the "video.publish" scope
#   3. Under Basic Information -> Redirect URI, add: http://localhost
#   4. Save your Client Key + Client Secret from the Credentials tab
#   5. Run: .\Get-TikTokToken.ps1 -ClientKey <key> -ClientSecret <secret>
#   6. Paste all four values printed below. Then use: .\generate.ps1 -Upload
#
# Mode: Direct Post (video.publish scope) — posts immediately to your TikTok profile at SELF_ONLY privacy.
#        To use draft/inbox mode instead, set Direct Post OFF in the portal and swap to video.upload scope.
# Note: Access tokens expire in ~24 hours. The pipeline auto-refreshes via TIKTOK_REFRESH_TOKEN.
# Re-run Get-TikTokToken.ps1 if the refresh token ever expires or is revoked.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# Output
OUTPUT_DIR=./output

# Channel
DEFAULT_CHANNEL_THEME=compressed-curiosity
DEFAULT_DAILY_TARGET=3

# Legacy n8n (not needed for MVP)
N8N_BASE_URL=
N8N_API_KEY=
N8N_SCOPE_FILE=n8n.scope.json
N8N_WORKFLOW_PREFIX=Vibe Printing -
